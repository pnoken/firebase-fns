# Appwrite Function Environment Variables
# Add these in your Appwrite Console under Functions > [Your Function] > Settings > Environment Variables

# Blockchain Configuration
RPC_URL=your_rpc_url_here
MINTER_PRIVATE_KEY=your_minter_private_key_here

# Appwrite Configuration
APPWRITE_ENDPOINT=your_appwrite_endpoint_here
APPWRITE_PROJECT_ID=your_appwrite_project_id_here
APPWRITE_API_KEY=your_appwrite_api_key_here
